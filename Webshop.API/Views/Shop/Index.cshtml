<h1 class="mb-4">Termékek</h1>
<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">
                <h5 class="card-title">@product.Name</h5>
                <p class="card-text">@product.Description</p>
                <p><strong>@product.Price Ft</strong></p>
                <p>Keszlet: @product.Stock db</p>
                <p>Kategoria: @product.Category?.Name</p>

                <button class="btn btn-success">Kosarba</button>
            </div>
        </div>
    }
</div>