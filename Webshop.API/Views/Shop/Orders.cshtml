@model List<Webshop.API.ViewModels.OrderViewModel>

@{
    ViewData["Title"] = "Rendeléseim";
}

<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rendeléseim</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background-color: #fdf8ff;
            }

            h2 {
                color: #6d4c7d;
                font-weight: bold;
            }

            .orders-card {
                background: white;
                border-radius: 20px;
                box-shadow: 0 8px 20px rgba(0,0,0,0.08);
                padding: 25px;
            }

            .btn-crystal {
                background-color: #8e7cc3;
                color: white;
                border-radius: 12px;
            }

                .btn-crystal:hover {
                    background-color: #b4a7d6;
                    color: white;
                }
    </style>
</head>
<body>

    <div class="container mt-5">
        <h2 class="text-center mb-4">📦 Rendeléseim</h2>

        @if (Model.Any())
        {
            <div class="orders-card">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Rendelés ID</th>
                            <th>Dátum</th>
                            <th>Státusz</th>
                            <th>Végösszeg</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.OrderId</td>
                                <td>@order.OrderDate.ToString("yyyy.MM.dd")</td>
                                <td>@order.Status</td>
                                <td>@order.TotalPrice.ToString("N0") Ft</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="orders-card text-center">
                <h4>Még nincsenek rendeléseid.</h4>

                <a href="/Home/Index" class="btn btn-crystal mt-3">
                    Vásárlás folytatása
                </a>
            </div>
        }

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>