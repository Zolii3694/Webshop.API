@model List<Webshop.API.ViewModels.OrderViewModel>

@{
    ViewData["Title"] = "Rendeléseim";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">📦 Rendeléseim</h2>

    @if (Model != null && Model.Any())
    {
        <div class="card p-4 shadow-sm">
            @foreach (var order in Model)
            {
                <div class="mb-4 border-bottom pb-3">
                    <h5>Rendelés #@order.Id</h5>

                    <p><strong>Dátum:</strong> @order.OrderDate.ToString("yyyy.MM.dd HH:mm")</p>
                    <p><strong>Név:</strong> @order.CustomerName</p>
                    <p><strong>Email:</strong> @order.Email</p>
                    <p><strong>Cím:</strong> @order.Address</p>

                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Termék</th>
                                <th>Mennyiség</th>
                                <th>Egységár</th>
                                <th>Összesen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in order.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitPrice.ToString("N0") Ft</td>
                                    <td>@((item.UnitPrice * item.Quantity).ToString("N0")) Ft</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <h5 class="text-end">
                        Végösszeg: @order.TotalPrice.ToString("N0") Ft
                    </h5>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card text-center p-4 shadow-sm">
            <h4>Még nincsenek rendeléseid.</h4>
            <a href="/Home/Index" class="btn btn-primary mt-3">Vásárlás folytatása</a>
        </div>
    }
</div>