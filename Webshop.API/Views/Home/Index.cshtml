@using Webshop.API.Models
@model Webshop.API.ViewModels.HomeViewModel

<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CrystalAura</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background-color: #fdf8ff;
            }

            .navbar {
                background: linear-gradient(90deg, #c8a2c8, #d9f2ef);
            }

            .navbar-brand {
                font-weight: bold;
                font-size: 1.7rem;
                color: white !important;
            }

            .navbar-toggler {
                border: none;
            }

            .card {
                border: none;
                border-radius: 20px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                transition: 0.3s;
            }

                .card:hover {
                    transform: translateY(-5px);
                }

            .btn-crystal {
                background-color: #8e7cc3;
                color: white;
                border-radius: 12px;
            }

                .btn-crystal:hover {
                    background-color: #b4a7d6;
                    color: white;
                }

            h2 {
                color: #6d4c7d;
                font-weight: bold;
            }

            .search-box {
                border-radius: 20px;
            }

            .category-btn {
                border-radius: 20px;
                padding: 8px 18px;
            }

            footer {
                margin-top: 60px;
                padding: 20px;
                text-align: center;
                color: #6d4c7d;
            }

            .card-img-top {
                height: 250px;
                object-fit: cover;
                border-top-left-radius: 20px;
                border-top-right-radius: 20px;
            }

            .empty-message {
                text-align: center;
                padding: 50px;
                color: #6d4c7d;
}
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">

            <a class="navbar-brand" href="/Home/Index">CrystalAura</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>



            <div class="collapse navbar-collapse" id="navbarMenu">

                <form method="get" action="/Home/Index" class="d-flex mx-auto w-50">
                    <input class="form-control me-2 search-box"
                           type="search"
                           name="search"
                           placeholder="Keress kristályt...">

                    <button type="submit" class="btn btn-light">
                        Keresés
                    </button>
                </form>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Account/Login">Profil</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Shop/Orders">Rendeléseim</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Cart">
                            Kosár
                        </a>
                    </li>
                </ul>

            </div>
        </div>
    </nav>

<div class="container mt-4">
        <div class="d-flex gap-2 flex-wrap justify-content-center">

            <button class="btn btn-outline-secondary category-btn">
                Összes
            </button>

            @foreach (var category in Model.Categories)
            {
                <button class="btn btn-outline-secondary category-btn">
                    @category.Name
                </button>
            }

        </div>
    </div>

    <div class="container mt-5">
        <h2 class="text-center mb-4">Fedezd fel kristályainkat</h2>

        <div class="row g-4">

            @if (Model.Products.Any())
            {
                @foreach (var product in Model.Products)
                {
                    <div class="col-md-4">
                        <div class="card h-100">

                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)"
                                 class="card-img-top"
                                 alt="@product.Name">

                            <div class="card-body">
                                <h5 class="card-title">
                                    @product.Name
                                </h5>

                                <p class="card-text">
                                    @product.Description
                                </p>

                                <p class="fw-bold">
                                    @product.Price.ToString("N0") Ft
                                </p>

                                <button class="btn btn-crystal w-100">
                                    Kosárba
                                </button>
                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-message">
                    <h4>Jelenleg nincsenek elérhető kristályok.</h4>
                </div>
            }

        </div>
</div>

    <footer>
        © 2025 CrystalAura — Minden jog fenntartva
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>